# ─── Neo4j ─────────────────────────────────────────────────────────────────────
# URI: host app → Docker published Bolt port (default 7687). Use bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# MUST match the password Neo4j was first initialized with (see NEO4J_AUTH on the container).
# Example: docker inspect <container_name> --format '{{range .Config.Env}}{{println .}}{{end}}' | findstr NEO4J_AUTH
# NEO4J_AUTH is neo4j/<password> — e.g. neo4j/password → set NEO4J_PASSWORD=password
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

# ─── Gemini / LangChain ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
USE_LLM=true

# ─── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Dataset bootstrap (R1) ────────────────────────────────────────────────────
DATA_DIR=data                          # local path for raw dataset files
AUTO_DOWNLOAD_DATASETS=true           # download missing datasets on startup
AUTO_INGEST_NEO4J=true               # ingest datasets into Neo4j on startup
FORCE_REINGEST=false                  # force re-ingest even if marker exists
INGEST_BATCH_SIZE=500                 # UNWIND batch size for Neo4j writes

# ─── Dataset size limits ───────────────────────────────────────────────────────
TWITTER_MAX_EDGES=50000               # cap Twitter edge ingest (large dataset)
REDDIT_MAX_ROWS=30000                 # cap Reddit row ingest

# ─── Dataset download URLs (override to use internal mirrors) ──────────────────
FACEBOOK_EDGES_URL=https://snap.stanford.edu/data/facebook_large.zip
TWITTER_EDGES_URL=https://snap.stanford.edu/data/twitter_combined.txt.gz
REDDIT_TITLE_URL=http://snap.stanford.edu/data/soc-redditHyperlinks-title.tsv

# ─── Chat insert safety (R5) ───────────────────────────────────────────────────
ALLOW_CHAT_INSERT=true                # set false in production to disable inserts
CHAT_INSERT_MAX_NODES=10              # max nodes per single /chat/insert request

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=8000
ENV=development

# ─── Kaggle CLI (kernels push: python scripts/push_kaggle_kernel.py) ───────────
# python-dotenv accepts KEY=value; in bash you may also: export KAGGLE_USERNAME=...
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_token